# Required: Zhipu AI API key from https://open.bigmodel.cn
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# Optional model. For free deployment, glm-4-flash is cheaper and friendlier to rate limits.
ZHIPUAI_MODEL=glm-4-flash

# Optional frontend origins, comma separated.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional. Leave empty locally to use SQLite. Set on Render to use Neon/Supabase/Postgres.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require
